{
  "name": "generator-ts-api",
  "displayName": "generator-ts-api",
  "description": "从后端API文档生成前端TypeScript/JavaScript代码",
  "version": "0.0.8",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "generator-ts-api.generate",
        "title": "生成api文档"
      },
      {
        "command": "generator-ts-api.generateFromUrl",
        "title": "从url生成api文档"
      },
      {
        "command": "generator-ts-api.generateFromFile",
        "title": "从文件生成api文档"
      }
    ],
    "configuration": {
      "title": "Generator TS API",
      "properties": {
        "generator-ts-api.framework": {
          "type": "string",
          "enum": [
            "react",
            "vue",
            "angular"
          ],
          "default": "react",
          "description": "目标前端框架"
        },
        "generator-ts-api.outputType": {
          "type": "string",
          "enum": [
            "ts",
            "js"
          ],
          "default": "ts",
          "description": "输出文件类型"
        },
        "generator-ts-api.apiDocsUrl": {
          "type": "string",
          "default": "",
          "description": "API文档URL"
        },
        "generator-ts-api.apiDocsPath": {
          "type": "string",
          "default": "",
          "description": "API文档本地路径"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "typescript": "^5.8.2",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "swagger-parser": "^10.0.3",
    "yaml": "^2.3.4",
    "openapi-types": "^12.1.3",
    "openapi-typescript": "^7.0.0"
  }
}
